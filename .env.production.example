# ─────────────────────────────────────────────────────────────
# Copia este archivo como ".env" junto a docker-compose.prod.yml
# y rellena TODOS los valores antes de desplegar.
#   cp .env.production.example .env
# Genera secretos fuertes con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────────────────────

# Base de datos
POSTGRES_USER=ppp_user
POSTGRES_PASSWORD=
POSTGRES_DB=ppp_db

# MinIO (almacenamiento de documentos)
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# OpenSearch
OPENSEARCH_PASSWORD=
DISABLE_OPENSEARCH=false

# JWT (obligatorios, 64+ caracteres)
JWT_SECRET=
JWT_REFRESH_SECRET=

# Frontend
CORS_ORIGINS=https://tu-dominio-frontend.com
FRONTEND_URL=https://tu-dominio-frontend.com
