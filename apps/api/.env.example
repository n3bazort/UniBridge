NODE_ENV=development
PORT=3001

# ─── Base de Datos ──────────────────────────────────────
DATABASE_URL="postgresql://ppp_user:ppp_password@localhost:5432/ppp_db?schema=public"

# ─── Redis ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CAMBIA_ESTO_POR_UN_SECRET_SEGURO_64_CHARS"
JWT_REFRESH_SECRET="CAMBIA_ESTO_POR_OTRO_SECRET_SEGURO_64_CHARS"

# ─── CORS ───────────────────────────────────────────────
# Separar múltiples orígenes con coma
CORS_ORIGINS=http://localhost:3000

# ─── MinIO (Almacenamiento de archivos) ─────────────────
# Para deshabilitar MinIO en producción sin storage propio:
DISABLE_MINIO=false
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=ppp_minio_admin
MINIO_SECRET_KEY=ppp_minio_password

# ─── OpenSearch (Búsqueda full-text) ────────────────────
DISABLE_OPENSEARCH=false
OPENSEARCH_URL=https://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=Ppp_os_password123!
