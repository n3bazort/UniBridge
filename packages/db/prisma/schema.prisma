generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  COORDINATOR
  STUDENT
  SIGNER
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  password  String
  role      Role
  firstName String?
  lastName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  suspendedAt DateTime?  // cuenta inhabilitada: no puede iniciar sesión (reversible)

  coordinator        Coordinator?
  studentProfile     Student?
  signerProfile      SignerProfile?
  refreshTokens      RefreshToken[]
  auditLogs          AuditLog[]
  excelImports       ExcelImport[]
  generatedDocuments GeneratedDocument[]
  invalidatedDocuments GeneratedDocument[] @relation("DocumentInvalidation")
  deanSignedItems    SignatureBatchItem[] @relation("ItemDeanSigner")
  finalSignedItems   SignatureBatchItem[] @relation("ItemFinalSigner")
  signatureBatches   SignatureBatch[]
  generationBatches  GenerationBatch[]
  userInvitations    UserInvitation[] @relation("UserInvitations")

  @@map("users")
}

model Faculty {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  abbreviation String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  coordinators  Coordinator[]
  programs      Program[]
  students      Student[]
  practices     Practice[]
  excelImports  ExcelImport[]
  documentTemplates DocumentTemplate[]
  userInvitations UserInvitation[]

  @@map("faculties")
}

model Coordinator {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid
  facultyId String   @db.Uuid
  programId String?  @db.Uuid  // carrera específica que coordina (la facultad se deriva de ella)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  user      User     @relation(fields: [userId], references: [id])
  faculty   Faculty  @relation(fields: [facultyId], references: [id])
  program   Program? @relation(fields: [programId], references: [id])

  @@map("coordinators")
}

model Program {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  abbreviation String?
  facultyId   String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  faculty     Faculty  @relation(fields: [facultyId], references: [id])
  students    Student[]
  coordinators Coordinator[]

  @@map("programs")
}

model Student {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @db.Uuid
  facultyId   String   @db.Uuid
  programId   String   @db.Uuid
  dni         String   @unique
  firstName   String
  lastName    String
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  user        User     @relation(fields: [userId], references: [id])
  faculty     Faculty  @relation(fields: [facultyId], references: [id])
  program     Program  @relation(fields: [programId], references: [id])
  practices   Practice[]
  generatedDocs GeneratedDocument[]

  @@map("students")
}

model Company {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @unique
  address       String?
  contactName   String?
  email         String?
  phone         String?
  recipientName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  practices     Practice[]

  @@map("companies")
}

enum PracticeStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
  DELAYED
  CANCELED
}

model Practice {
  id              String   @id @default(uuid()) @db.Uuid
  studentId       String   @db.Uuid
  companyId       String   @db.Uuid
  facultyId       String   @db.Uuid
  academicPeriod  String   @default("2024-1")
  tutorName       String?  
  practiceLevel   String?  
  academicLevel   String?
  status          PracticeStatus @default(PENDING)
  startDate       DateTime?
  endDate         DateTime?
  totalHours      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  student         Student  @relation(fields: [studentId], references: [id])
  company         Company  @relation(fields: [companyId], references: [id])
  faculty         Faculty  @relation(fields: [facultyId], references: [id])
  period          AcademicPeriod? @relation(fields: [academicPeriod], references: [code])

  @@map("practices")
}

model DocumentTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  type        String   
  content     Json     
  facultyId   String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  faculty     Faculty  @relation(fields: [facultyId], references: [id])
  generatedDocs GeneratedDocument[]

  @@map("document_templates")
}

enum DocumentStatus {
  VALID
  INVALIDATED
  SUPERSEDED
}

model GeneratedDocument {
  id            String   @id @default(uuid()) @db.Uuid
  templateId    String   @db.Uuid
  studentId     String   @db.Uuid
  generatedById String?  @db.Uuid
  fileUrl       String   // objectKey en MinIO (no URL absoluta)
  documentCode  String?
  documentType  String?
  status        DocumentStatus @default(VALID)
  invalidatedAt DateTime?
  invalidReason String?
  invalidatedById String? @db.Uuid  // quién lo invalidó (trazabilidad)
  version       Int      @default(1)
  replacedById  String?  @db.Uuid
  createdAt     DateTime @default(now())
  deletedAt     DateTime?

  // ── Flujo de firma digital ──
  signatureStatus SignatureStatus @default(NONE)
  signedFileKey   String?         // objectKey del PDF con ambas firmas
  signedChecksum  String?         // SHA-256 del archivo firmado final
  signedAt        DateTime?

  template      DocumentTemplate @relation(fields: [templateId], references: [id])
  student       Student          @relation(fields: [studentId], references: [id])
  generatedBy   User?            @relation(fields: [generatedById], references: [id])
  invalidatedBy User?            @relation("DocumentInvalidation", fields: [invalidatedById], references: [id])
  replacedBy    GeneratedDocument? @relation("DocumentReplacement", fields: [replacedById], references: [id])
  replaces      GeneratedDocument[] @relation("DocumentReplacement")
  signatureItems SignatureBatchItem[]

  @@map("generated_documents")
}

// ═══════════════ FIRMA DIGITAL (FirmaEC) ═══════════════

enum SignatureStatus {
  NONE            // no requiere firma / no enviado
  IN_SIGNING      // dentro de un lote de firma en curso
  PARTIALLY_SIGNED// firmado por la primera autoridad
  SIGNED          // firmado por ambas autoridades y publicado
  REJECTED        // rechazado por un firmante
}

enum SignerRole {
  DEAN      // Decano: firma primero
  DIRECTOR  // Director: firma sobre el PDF ya firmado por el decano
}

// Invitación genérica para que cualquier rol se auto-registre (ADMIN, COORDINATOR, SIGNER)
// mediante un link con token de un solo uso.
model UserInvitation {
  id          String     @id @default(uuid()) @db.Uuid
  token       String     @unique
  role        Role       @default(SIGNER)
  signerRole  SignerRole?
  facultyId   String?    @db.Uuid
  programId   String?    @db.Uuid  // carrera que coordinará (deriva la facultad)
  email       String?    // si el admin la fija, el registro exige este correo
  fullName    String?    // pre-llenado opcional
  expiresAt   DateTime
  usedAt      DateTime?
  createdById String     @db.Uuid
  createdAt   DateTime   @default(now())

  createdBy   User       @relation("UserInvitations", fields: [createdById], references: [id])
  faculty     Faculty?   @relation(fields: [facultyId], references: [id])

  @@map("user_invitations")
}

// Vincula a un usuario con rol SIGNER con la autoridad que representa
model SignerProfile {
  id         String     @id @default(uuid()) @db.Uuid
  userId     String     @unique @db.Uuid
  signerRole SignerRole
  fullName   String
  title      String?    // ej. "Decano de la Facultad de Ciencias de la Vida"
  createdAt  DateTime   @default(now())

  user       User @relation(fields: [userId], references: [id])

  @@map("signer_profiles")
}

enum SignatureBatchStatus {
  PENDING_DEAN     // esperando firma del decano
  PENDING_DIRECTOR // esperando firma del director
  COMPLETED        // ambas firmas subidas y publicadas
  CANCELLED
}

model SignatureBatch {
  id          String               @id @default(uuid()) @db.Uuid
  code        String               @unique // ej. LOTE-2026-1-00001
  name        String?
  status      SignatureBatchStatus @default(PENDING_DEAN)
  createdById String               @db.Uuid
  deanSignedAt     DateTime?
  directorSignedAt DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  createdBy   User                 @relation(fields: [createdById], references: [id])
  items       SignatureBatchItem[]

  @@map("signature_batches")
}

enum SignatureItemStatus {
  PENDING        // sin firmas
  SIGNED_BY_DEAN // primera firma subida y verificada
  SIGNED         // ambas firmas subidas y verificadas
  REJECTED
}

model SignatureBatchItem {
  id             String              @id @default(uuid()) @db.Uuid
  batchId        String              @db.Uuid
  documentId     String              @db.Uuid
  status         SignatureItemStatus @default(PENDING)
  deanFileKey    String?             // objectKey del PDF firmado por el decano
  deanChecksum   String?
  deanSignedById String?             @db.Uuid  // qué usuario firmó como Decano
  finalFileKey   String?             // objectKey del PDF con ambas firmas
  finalChecksum  String?
  finalSignedById String?            @db.Uuid  // qué usuario firmó como Responsable
  rejectReason   String?
  updatedAt      DateTime            @updatedAt
  createdAt      DateTime            @default(now())

  batch          SignatureBatch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  document       GeneratedDocument @relation(fields: [documentId], references: [id])
  deanSignedBy   User?             @relation("ItemDeanSigner", fields: [deanSignedById], references: [id])
  finalSignedBy  User?             @relation("ItemFinalSigner", fields: [finalSignedById], references: [id])

  @@unique([batchId, documentId])
  @@map("signature_batch_items")
}

// ═══════════════ GENERACIÓN MASIVA (BullMQ) ═══════════════

enum GenerationBatchStatus {
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
}

model GenerationBatch {
  id          String                @id @default(uuid()) @db.Uuid
  templateId  String                @db.Uuid
  total       Int
  completed   Int                   @default(0)
  failed      Int                   @default(0)
  status      GenerationBatchStatus @default(PROCESSING)
  createdById String?               @db.Uuid
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  createdBy   User? @relation(fields: [createdById], references: [id])

  @@map("generation_batches")
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model ExcelImport {
  id          String   @id @default(uuid()) @db.Uuid
  fileName    String
  fileUrl     String
  status      ImportStatus @default(PENDING)
  facultyId   String   @db.Uuid
  uploadedBy  String   @db.Uuid
  errorLogs   Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  faculty     Faculty  @relation(fields: [facultyId], references: [id])
  user        User     @relation(fields: [uploadedBy], references: [id])

  @@map("excel_imports")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  userId    String   @db.Uuid
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user      User     @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @db.Uuid
  action     String
  tableName  String
  recordId   String   @db.Uuid
  oldData    Json?
  newData    Json?
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model AcademicPeriod {
  id            String   @id @default(uuid()) @db.Uuid
  code          String   @unique
  name          String
  startDate     DateTime
  endDate       DateTime
  isActive      Boolean  @default(false)
  
  deanName      String? 
  directorName  String? 

  practices     Practice[]
  sequences     DocumentSequence[]

  @@map("academic_periods")
}

model DocumentSequence {
  id          String   @id @default(uuid()) @db.Uuid
  type        String   
  periodCode  String   
  lastNumber  Int      @default(0)
  
  period      AcademicPeriod @relation(fields: [periodCode], references: [code])

  @@unique([type, periodCode])
  @@map("document_sequences")
}
